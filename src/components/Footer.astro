<!-- MODAL DE REPRODUCTOR DE VIDEO DE YOUTUBE -->
<div 
  id="video-modal" 
  class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-md transition-all duration-300"
>
  <div class="relative w-full max-w-4xl mx-4 aspect-video bg-[#050720] rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl">
    <!-- Close Button -->
    <button 
      id="close-modal" 
      class="absolute top-4 right-4 text-white/70 hover:text-white bg-white/10 hover:bg-white/20 p-2.5 rounded-full transition z-10"
      aria-label="Cerrar modal"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <!-- Iframe container -->
    <div id="video-iframe-container" class="w-full h-full"></div>
  </div>
</div>

<script>
  // Script del lado del cliente para manejar la reproducción de videos en el modal
  const playButtons = document.querySelectorAll("[data-play-btn]");
  const modal = document.getElementById("video-modal");
  const closeModalBtn = document.getElementById("close-modal");
  const iframeContainer = document.getElementById("video-iframe-container");

  if (modal && closeModalBtn && iframeContainer) {
    // Función para abrir el modal
    const openModal = (youtubeId) => {
      iframeContainer.innerHTML = `
        <iframe 
          src="https://www.youtube.com/embed/${youtubeId}?autoplay=1" 
          class="w-full h-full" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      `;
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden"; // Deshabilita scroll de fondo
    };

    // Función para cerrar el modal
    const closeModal = () => {
      modal.classList.add("hidden");
      iframeContainer.innerHTML = ""; // Destruye el iframe para cortar el video y audio
      document.body.style.overflow = ""; // Reactiva scroll de fondo
    };

    // Eventos de apertura
    playButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const youtubeId = btn.getAttribute("data-youtube-id");
        if (youtubeId) {
          openModal(youtubeId);
        }
      });
    });

    // Evento de cierre (botón)
    closeModalBtn.addEventListener("click", closeModal);

    // Evento de cierre (hacer click fuera del contenedor del video / backdrop)
    modal.addEventListener("click", (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Soporte para tecla Esc
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        closeModal();
      }
    });
  }

  // Lógica del Slideshow de Himnos (PowerPoint Style)
  const slides = document.querySelectorAll(".anthem-slide");
  const prevBtn = document.getElementById("anthem-prev");
  const nextBtn = document.getElementById("anthem-next");
  const slideshowContainer = document.getElementById("anthems-slideshow-container");
  const slideshowBg = document.getElementById("slideshow-bg");

  if (slides.length > 0 && prevBtn && nextBtn && slideshowContainer) {
    let activeIndex = 0;

    const updateButtonsVisibility = () => {
      // Anterior: ocultar si estamos en el primer slide
      if (activeIndex === 0) {
        prevBtn.classList.add("invisible", "pointer-events-none");
      } else {
        prevBtn.classList.remove("invisible", "pointer-events-none");
      }

      // Siguiente: ocultar si estamos en el último slide
      if (activeIndex === slides.length - 1) {
        nextBtn.classList.add("invisible", "pointer-events-none");
      } else {
        nextBtn.classList.remove("invisible", "pointer-events-none");
      }
    };

    const updateSlideshow = (newIndex) => {
      // Ocultar slide actual
      const currentSlide = slides[activeIndex];
      currentSlide.classList.remove("active");
      currentSlide.classList.add("hidden");

      // Actualizar índice
      activeIndex = newIndex;

      // Mostrar nuevo slide
      const nextSlide = slides[activeIndex];
      nextSlide.classList.remove("hidden");
      nextSlide.classList.add("active");

      // Actualizar imagen de fondo dinámica
      if (slideshowBg) {
        const newBgUrl = nextSlide.getAttribute("data-bg-url");
        slideshowBg.style.opacity = "0";
        setTimeout(() => {
          if (newBgUrl) {
            slideshowBg.style.backgroundImage = `url('${newBgUrl}')`;
            slideshowBg.style.opacity = "0.35"; // Opacidad del 35% para que la imagen de fondo se distinga mejor
          } else {
            slideshowBg.style.backgroundImage = "none";
          }
        }, 150);
      }

      // Actualizar visibilidad de botones
      updateButtonsVisibility();
    };

    // Inicializar el primer fondo
    if (slideshowBg && slides.length > 0) {
      const initialBgUrl = slides[0].getAttribute("data-bg-url");
      if (initialBgUrl) {
        slideshowBg.style.backgroundImage = `url('${initialBgUrl}')`;
        slideshowBg.style.opacity = "0.35";
      }
    }

    // Inicializar la visibilidad de los botones al cargar
    updateButtonsVisibility();

    // Navegación con clicks (sin bucle infinito)
    prevBtn.addEventListener("click", (e) => {
      e.preventDefault();
      if (activeIndex > 0) {
        updateSlideshow(activeIndex - 1);
      }
    });

    nextBtn.addEventListener("click", (e) => {
      e.preventDefault();
      if (activeIndex < slides.length - 1) {
        updateSlideshow(activeIndex + 1);
      }
    });

    // Navegación por teclado (sin bucle infinito)
    document.addEventListener("keydown", (e) => {
      // Ignorar si el usuario está escribiendo en algún input/textarea
      const activeEl = document.activeElement;
      if (activeEl && (activeEl.tagName === "INPUT" || activeEl.tagName === "TEXTAREA" || activeEl.isContentEditable)) {
        return;
      }

      // Solo si el elemento del slideshow está en el viewport
      const rect = slideshowContainer.getBoundingClientRect();
      const isVisible = rect.top < window.innerHeight && rect.bottom > 0;

      if (isVisible) {
        if (e.key === "ArrowLeft" && activeIndex > 0) {
          prevBtn.click();
        } else if (e.key === "ArrowRight" && activeIndex < slides.length - 1) {
          nextBtn.click();
        }
      }
    });
  }
</script>

<style>
  /* Ocultar barra de scroll nativa pero mantener funcionalidad */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  /* Animación estilo PowerPoint (Fade + Slide) */
  @keyframes fadeInSlide {
    from {
      opacity: 0;
      transform: translateX(8px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .anthem-slide.active {
    animation: fadeInSlide 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
