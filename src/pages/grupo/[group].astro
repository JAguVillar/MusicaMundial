---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamCard from '../../components/TeamCard.astro';
import SpotifyEmbed from '../../components/SpotifyEmbed.astro';
import { worldCupGroups, teams } from '../../data/worldCupGroups.js';
import { getSpotifySource } from '../../data/musicSources.js';

export function getStaticPaths() {
  return worldCupGroups.map((group) => ({ params: { group: group.group.toLowerCase() }, props: { group } }));
}

const { group } = Astro.props;
const groupTeams = teams.filter((team) => team.group === group.group);
const featuredTeam = groupTeams.find((team) => getSpotifySource(team).status === 'ready') || groupTeams[0];
const featuredSource = getSpotifySource(featuredTeam);
---
<BaseLayout title={`Grupo ${group.group} | Música Mundial`} description={`Soundtracks del Grupo ${group.group} del Mundial 2026.`}>
  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <a href="/" class="inline-flex items-center gap-2 border border-slate-950 text-slate-950 hover:bg-slate-950 hover:text-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-5 py-2 text-xs font-black uppercase tracking-wider transition-all duration-200">← Volver a home</a>

    <div class="mt-6 rounded-[2.5rem] rounded-bl-[80px] bg-[#12135a] p-8 md:p-12 text-white shadow-xl">
      <p class="text-xs font-extrabold uppercase tracking-[0.35em] text-cyan-200">Soundtrack del grupo</p>
      <h1 class="mt-3 text-6xl font-black leading-none text-white md:text-8xl">Grupo {group.group}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-indigo-100">
        Cuatro selecciones, cuatro escenas musicales. Esta vista compara rápidamente los enlaces y embeds disponibles para el grupo.
      </p>
    </div>

    <section class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {groupTeams.map((team) => <TeamCard team={team} />)}
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div class="rounded-[2rem] border border-slate-100 bg-slate-50/70 p-6 md:p-8 shadow-sm">
        <p class="text-xs font-extrabold uppercase tracking-[0.32em] text-indigo-600">Embed destacado</p>
        <h2 class="mt-3 flex items-center gap-3 text-3xl font-black text-slate-900">
          <img
            src={`https://play.fifa.com/media/image/bracket_predictor/flags/world_cup_2026/${featuredTeam.fifaCode}.png`}
            alt=""
            class="h-8 w-auto object-contain"
          />
          {featuredTeam.name}
        </h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Mostramos el primer país del grupo con playlist curada. Cuando todos los países tengan IDs, esta sección puede evolucionar a una playlist combinada del grupo.
        </p>
      </div>
      <SpotifyEmbed source={featuredSource} title={`Spotify destacado Grupo ${group.group}`} />
    </section>
  </main>
</BaseLayout>
