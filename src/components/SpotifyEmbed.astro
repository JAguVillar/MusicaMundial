---
import SpotifyIcon from "./icons/spotify.astro";
const { source, title = 'Playlist de Spotify' } = Astro.props;
---
<div class="overflow-hidden rounded-[2rem] border border-white/10 bg-black/30 p-3 shadow-2xl shadow-black/30 backdrop-blur">
  {source.status === 'ready' ? (
    <iframe
      class="h-[420px] w-full rounded-[1.5rem] md:h-[520px]"
      src={source.embedUrl}
      title={title}
      width="100%"
      height="520"
      frameborder="0"
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
    ></iframe>
  ) : (
    <div class="flex min-h-[320px] flex-col items-center justify-center gap-5 rounded-[1.5rem] border border-dashed border-white/20 bg-white/[0.04] p-8 text-center">
      <div class="text-6xl">🎧</div>
      <div>
        <p class="text-xl font-bold text-white">Playlist por confirmar</p>
        <p class="mt-2 max-w-md text-sm text-slate-300">Todavía no hay un embed curado para esta selección. La estructura queda lista para pegar el ID de Spotify cuando lo tengamos.</p>
      </div>
      <a class="rounded-full bg-limewave px-5 py-3 text-sm font-black text-pitch transition hover:-translate-y-0.5 hover:bg-white inline-flex items-center gap-2" href={source.openUrl} target="_blank" rel="noreferrer">
        <SpotifyIcon class="w-4 h-4" />
        Buscar en Spotify
      </a>
    </div>
  )}
</div>
