---
import TeamCard from "./TeamCard.astro";
import PillButton from "./ui/PillButton.astro";
import { slugifyTeam } from "../data/worldCupGroups.js";

const { group } = Astro.props;
---

<section
  id={`grupo-${group.group}`}
  class={`scroll-mt-8 rounded-[2rem] p-5 md:p-7  ${group.theme.bg}`}
>
  <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class={`text-xs font-extrabold uppercase  ${group.theme.text}`}>
        Grupo
      </p>
      <h2 class="text-3xl font-black text-slate-900">{group.group}</h2>
    </div>
    <PillButton
      href={`/grupo/${group.group.toLowerCase()}/`}
      themeClass={group.theme.verGruposBtn}
    >
      Ver grupo
    </PillButton>
  </div>
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    {
      group.teams.map((team) => (
        <TeamCard
          team={{
            ...team,
            group: group.group,
            slug: slugifyTeam(team),
            theme: group.theme,
          }}
        />
      ))
    }
  </div>
</section>
