---
import { getCultureImage } from '../utils/image.js';
import ProgressiveImage from './ui/ProgressiveImage.astro';
import SpotifyIcon from './icons/spotify.astro';
import PillButton from './ui/PillButton.astro';

interface Props {
  team: any;
  source: any;
}

const { team, source } = Astro.props;
const cultureImg = getCultureImage(team);
---

<div
  class="relative overflow-hidden rounded-[2.5rem] rounded-bl-[80px] bg-[#12135a] text-white shadow-xl transition-all duration-300 w-full"
>
  <!-- Imagen de fondo con carga progresiva -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <ProgressiveImage
      src={cultureImg}
      alt=""
      loading="eager"
    />
  </div>
  <div
    class="absolute inset-0 z-0 bg-gradient-to-t from-[#12135a] via-[#12135a]/70 to-[#12135a]/35"
  >
  </div>

  <!-- Cuerpo de la Tarjeta -->
  <div class="relative z-10 p-8 md:p-10 flex flex-col">
    <div>
      <img
        src={`https://play.fifa.com/media/image/bracket_predictor/flags/world_cup_2026/${team.fifaCode}.png`}
        alt={`Bandera de ${team.name}`}
        loading="lazy"
        decoding="async"
        class="h-16 w-auto object-contain"
      />
    </div>

    <p class="mt-6 text-xs font-extrabold uppercase text-cyan-200">
      Grupo {team.group}
    </p>
    <h1
      class="mt-3 text-5xl font-black leading-none text-white md:text-6xl"
    >
      {team.name}
    </h1>
    {
      team.nativeName && (
        <p class="mt-2 text-xl font-semibold text-cyan-200/90 tracking-wide">
          {team.nativeName}
        </p>
      )
    }

    <div class="mt-8 grid gap-3 grid-cols-2">
      <!-- Tarjeta 1: Confederación -->
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 flex flex-col justify-between">
        <div>
          <p class="text-sm text-indigo-200">Confederación</p>
          <p class="mt-1 text-2xl font-black text-white">
            {team.profile.confederation}
          </p>
        </div>
        <p class="mt-2 text-xs text-indigo-300 font-medium leading-tight">
          {team.profile.qualificationRoute}
        </p>
      </div>

      <!-- Tarjeta 2: Capital -->
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 flex flex-col justify-between">
        <div>
          <p class="text-sm text-indigo-200">Capital</p>
          <p class="mt-1 text-2xl font-black text-white leading-tight">
            {team.profile.capital}
          </p>
        </div>
        {team.profile.capitalNativeName && team.profile.capitalNativeName !== team.profile.capital && (
          <p class="mt-2 text-xs text-indigo-300 font-semibold tracking-wide">
            {team.profile.capitalNativeName}
          </p>
        )}
      </div>

      <!-- Tarjeta 3: Participaciones -->
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 flex flex-col justify-between">
        <div>
          <p class="text-sm text-indigo-200">Mundiales</p>
          <p class={`mt-1 font-black text-white leading-tight ${team.profile.worldCupAppearances === 0 ? 'text-lg md:text-xl' : 'text-2xl'}`}>
            {team.profile.worldCupAppearances === 0 ? "Debut mundialista" : team.profile.worldCupAppearances}
          </p>
        </div>
        {team.profile.worldCupAppearances > 0 && (
          <p class="mt-2 text-xs text-indigo-300 font-medium">
            {team.profile.worldCupAppearances === 1 ? "participación" : "participaciones"}
          </p>
        )}
      </div>

      <!-- Tarjeta 4: Ranking FIFA (Condicional) -->
      {team.profile.fifaRanking !== null && (
        <div class="rounded-2xl border border-white/10 bg-white/10 p-4 flex flex-col justify-between">
          <div>
            <p class="text-sm text-indigo-200">Ranking FIFA</p>
            <p class="mt-1 text-2xl font-black text-white">
              #{team.profile.fifaRanking}
            </p>
          </div>
          <p class="mt-2 text-xs text-indigo-300 font-medium">
            posición oficial
          </p>
        </div>
      )}
    </div>
    <p
      class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm leading-7 text-indigo-100"
    >
      {source.sourceNote}
    </p>

    <div class="mt-6 flex">
      <PillButton
        href={source.openUrl}
        target="_blank"
        rel="noreferrer"
        themeClass="border-2 border-white bg-white text-[#12135a] hover:bg-[#12135a] hover:text-white hover:border-white px-6 py-3"
      >
        <SpotifyIcon class="w-4 h-4" />
        Abrir en Spotify
      </PillButton>
    </div>
  </div>
</div>
