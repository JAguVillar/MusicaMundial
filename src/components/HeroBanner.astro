---
import SpotifyIcon from "./icons/spotify.astro";
import {
  Users,
  LayoutGrid,
  Activity,
  RefreshCw,
  Headphones,
  ChevronDown,
} from "lucide-astro";

const featuredFlags = [
  { name: "Argentina", code: "ARG" },
  { name: "Brasil", code: "BRA" },
  { name: "España", code: "ESP" },
  { name: "Francia", code: "FRA" },
  { name: "México", code: "MEX" },
  { name: "Japón", code: "JPN" },
  { name: "Corea del Sur", code: "KOR" },
  { name: "Alemania", code: "GER" },
  { name: "Portugal", code: "POR" },
  { name: "Inglaterra", code: "ENG" },
  { name: "Uruguay", code: "URU" },
  { name: "Colombia", code: "COL" },
];
---

<div
  class="relative bg-[#06092b] rounded-bl-[40px] md:rounded-bl-[80px] lg:rounded-bl-[280px] flex flex-col items-center px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24 text-center overflow-hidden min-h-[78svh] lg:min-h-[84svh]"
  aria-label="Hero Música Mundial"
>
  <div
    class="relative z-10 mx-auto flex w-full max-w-5xl flex-1 flex-col items-center justify-center gap-6"
  >
    <p class="text-xs font-black uppercase tracking-[0.25em] text-cyan-400">
      Soundtracks del Mundial 2026
    </p>

    <h1
      class="font-display font-black uppercase text-white leading-[0.88] tracking-tight text-6xl sm:text-7xl md:text-8xl lg:text-9xl"
    >
      Música<br />Mundial 26
    </h1>

    <p
      class="max-w-2xl text-balance text-sm sm:text-base font-semibold leading-relaxed text-indigo-100/80"
    >
      Una radio visual del torneo: cada selección con sus colores, su grupo y
      una playlist pública de Spotify para escuchar lo que suena en el país.
    </p>

    <div class="flex flex-wrap justify-center gap-2.5 max-w-3xl">
      <!-- badges igual que ahora -->
    </div>

    <div class="mt-2 flex flex-col items-center gap-3">
      <a
        href="#grupos"
        class="group inline-flex items-center gap-2.5 bg-[#3ddcff] hover:bg-white text-black font-black uppercase text-xs tracking-wider px-7 py-4 rounded-full transition duration-300 hover:shadow-white/10 hover:-translate-y-0.5"
      >
        <Headphones class="w-4 h-4" />
        Explorar grupos
        <ChevronDown
          class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-0.5"
        />
      </a>

      <a
        href="#grupos"
        class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-[0.2em] text-cyan-300/70 transition hover:text-cyan-300"
        aria-label="Ir a grupos"
      >
        Descubrir selecciones
      </a>
    </div>
  </div>
</div>

<style>
  /* Animación slow rotate para el icono de sync */
  .animate-spin-slow {
    animation: spin 8s linear infinite;
  }
  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
