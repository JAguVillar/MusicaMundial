---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SpotifyEmbed from "../../components/SpotifyEmbed.astro";
import TeamCard from "../../components/TeamCard.astro";
import { teams } from "../../data/worldCupGroups.js";
import { getSpotifySource } from "../../data/musicSources.js";

export function getStaticPaths() {
  return teams.map((team) => ({
    params: { slug: team.slug },
    props: { team },
  }));
}

const { team } = Astro.props;
const source = getSpotifySource(team);
const isReady = source.status === "ready";
const groupMates = teams.filter(
  (item) => item.group === team.group && item.slug !== team.slug,
);

// Se obtiene la imagen desde la base de datos (team.image).
// Si no existe, se genera una de forma dinámica de Unsplash basada en el nombre del país para poblar automáticamente todas las selecciones.
const cultureImg =
  team.image ||
  `https://images.unsplash.com/featured/800x600/?${encodeURIComponent(team.name)},culture,landscape`;
---

<BaseLayout
  title={`${team.name} | Música Mundial`}
  description={`Playlist y soundtrack de ${team.name} para el Mundial 2026.`}
>
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <a
      href="/"
      class="inline-flex items-center gap-2 border border-slate-950 text-slate-950 hover:bg-slate-950 hover:text-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-5 py-2 text-xs font-black uppercase tracking-wider transition-all duration-200"
      >← Volver a grupos</a
    >

    <section class={isReady ? "mt-6 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start" : "mt-6"}>
      <!-- Tarjeta del País (Diseño A: Imagen de fondo integrada con clases Tailwind nativas) -->
      <div
        class="relative overflow-hidden rounded-[2.5rem] rounded-bl-[80px] bg-[#12135a] text-white shadow-xl transition-all duration-300"
      >
        <!-- Imagen de fondo -->
        <div
          class="absolute inset-0 z-0 bg-cover bg-center"
          style={`background-image: url('${cultureImg}')`}
        >
        </div>
        <div
          class="absolute inset-0 z-0 bg-gradient-to-t from-[#12135a] via-[#12135a]/70 to-[#12135a]/35"
        >
        </div>

        <!-- Cuerpo de la Tarjeta -->
        <div class="relative z-10 p-8 md:p-10 flex flex-col">
          <div>
            <img
              src={`https://play.fifa.com/media/image/bracket_predictor/flags/world_cup_2026/${team.fifaCode}.png`}
              alt={`Bandera de ${team.name}`}
              class="h-16 w-auto object-contain"
            />
          </div>

          <p class="mt-6 text-xs font-extrabold uppercase text-cyan-200">
            Grupo {team.group}
          </p>
          <h1
            class="mt-3 text-5xl font-black leading-none text-white md:text-6xl"
          >
            {team.name}
          </h1>
          {
            team.nativeName && (
              <p class="mt-2 text-xl font-semibold text-cyan-200/90 tracking-wide">
                {team.nativeName}
              </p>
            )
          }

          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
              <p class="text-sm text-indigo-200">Código</p>
              <p class="mt-1 text-2xl font-black text-white">
                {team.countryCode}
              </p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
              <p class="text-sm text-indigo-200">Estado musical</p>
              <p class="mt-1 text-lg font-black text-white">{source.label}</p>
            </div>
          </div>
          <p
            class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm leading-7 text-indigo-100"
          >
            {source.sourceNote}
          </p>
          <a
            href={source.openUrl}
            target="_blank"
            rel="noreferrer"
            class="mt-6 inline-flex border-2 border-white bg-white text-[#12135a] hover:bg-[#12135a] hover:text-white hover:border-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-6 py-3 text-xs font-black uppercase tracking-wider transition-all duration-200 justify-center items-center"
            >Abrir en Spotify</a
          >
        </div>
      </div>

      {isReady && (
        <!-- Spotify Embed -->
        <SpotifyEmbed source={source} title={`Top 50 Spotify ${team.name}`} />
      )}
    </section>

    <!-- Rivales del mismo grupo -->
    <section class="mt-12">
      <div class="mb-5 flex items-center justify-between gap-3">
        <div>
          <p class="text-xs font-extrabold uppercase text-indigo-600">
            También en el grupo {team.group}
          </p>
          <h2 class="mt-2 text-3xl font-black text-slate-900">
            Rivales musicales
          </h2>
        </div>
        <a
          href={`/grupo/${team.group.toLowerCase()}/`}
          class="border border-slate-950 text-slate-950 hover:bg-slate-950 hover:text-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-5 py-2 text-xs font-black uppercase tracking-wider transition-all duration-200"
          >Ver grupo</a
        >
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {groupMates.map((mate) => <TeamCard team={mate} />)}
      </div>
    </section>
  </main>
</BaseLayout>
