---
import { getSpotifySource } from "../data/musicSources.js";

const { team } = Astro.props;
const source = getSpotifySource(team);
const theme = team.theme || {
  text: "text-indigo-600",
  border: "border-indigo-200",
  bg: "bg-indigo-50/50",
  accent: "text-indigo-500",
  hoverBorder: "group-hover:border-indigo-300",
  hoverShadow: "hover:shadow-indigo-100/50",
  hoverText: "group-hover:text-indigo-600",
  badge: "bg-indigo-50 text-indigo-700 border-indigo-200/50",
  hoverBg: "rgba(238, 242, 255, 0.65)",
};
const isReady = source.status === "ready";

const hoverBg = theme.hoverBg || "rgba(248, 250, 252, 0.65)";
const cardBorder = theme.border || "border-slate-200";
---

{
  isReady ? (
    <a
      href={`/pais/${team.slug}/`}
      class={`group block rounded-[1.5rem] border-2 ${cardBorder} bg-white p-5 transition-all duration-300 hover:bg-[var(--hover-bg)] ${theme.hoverBorder} ${theme.hoverShadow}`}
      style={`--hover-bg: ${hoverBg};`}
    >
      <div class="flex items-start justify-between gap-4">
        <div>
          <img
            src={`https://play.fifa.com/media/image/bracket_predictor/flags/world_cup_2026/${team.fifaCode}.png`}
            alt={`Bandera de ${team.name}`}
            class="h-9 w-auto object-contain"
          />

          <h3 class="mt-1 text-xl font-black text-slate-900 group-hover:text-indigo-950">
            {team.name}
          </h3>
        </div>
      </div>
      <div class="mt-6 flex items-end justify-between">
        <div
          class={`flex h-8 items-end gap-1 ${theme.accent}`}
          aria-hidden="true"
        >
          <span class="equalizer-bar h-5 w-1.5 rounded-full bg-current" />
          <span class="equalizer-bar h-8 w-1.5 rounded-full bg-current" />
          <span class="equalizer-bar h-6 w-1.5 rounded-full bg-current" />
          <span class="equalizer-bar h-4 w-1.5 rounded-full bg-current" />
        </div>
        <span
          class={`text-xs font-black uppercase tracking-wider text-slate-700 transition ${theme.hoverText}`}
        >
          Escuchar →
        </span>
      </div>
    </a>
  ) : (
    <a
      href={`/pais/${team.slug}/`}
      class={`group block rounded-[1.5rem] border ${cardBorder} bg-white p-5 shadow-sm transition-all duration-300 hover:bg-[var(--hover-bg)] ${theme.hoverBorder} ${theme.hoverShadow}`}
      style={`--hover-bg: ${hoverBg};`}
    >
      <div class="flex items-start justify-between gap-4">
        <div>
          <img
            src={`https://play.fifa.com/media/image/bracket_predictor/flags/world_cup_2026/${team.fifaCode}.png`}
            alt={`Bandera de ${team.name}`}
            class="h-9 w-auto object-contain"
          />
          <p class={`mt-3 text-[10px] font-extrabold uppercase ${theme.text}`}>
            Grupo {team.group}
          </p>
          <h3 class="mt-1 text-xl font-black text-slate-900 group-hover:text-indigo-950">
            {team.name}
          </h3>
        </div>
      </div>
      <div class="mt-6 flex items-end justify-between">
        <div
          class={`flex h-8 items-end pb-1 gap-1.5 ${theme.accent} opacity-50`}
          aria-hidden="true"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-current" />
          <span class="h-1.5 w-1.5 rounded-full bg-current" />
          <span class="h-1.5 w-1.5 rounded-full bg-current" />
          <span class="h-1.5 w-1.5 rounded-full bg-current" />
        </div>
      </div>
    </a>
  )
}
