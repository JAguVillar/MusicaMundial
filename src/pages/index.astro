---
import BaseLayout from '../layouts/BaseLayout.astro';
import GroupSection from '../components/GroupSection.astro';
import { teams, worldCupGroups } from '../data/worldCupGroups.js';
import { getSpotifySource } from '../data/musicSources.js';

const readyCount = teams.filter((team) => getSpotifySource(team).status === 'ready').length;
const heroTeams = [
  { name: 'México', flag: '🇲🇽', colors: 'from-emerald-500 via-white to-red-500', note: 'Top 50 · Grupo A' },
  { name: 'Brasil', flag: '🇧🇷', colors: 'from-green-500 via-yellow-300 to-blue-600', note: 'Samba pop · Grupo C' },
  { name: 'Estados Unidos', flag: '🇺🇸', colors: 'from-blue-700 via-white to-red-600', note: 'Host sound · Grupo D' }
];
---
<BaseLayout title="Música Mundial | Soundtracks del Mundial 2026">
  <main>
    <section class="worldcup-hero relative flex min-h-screen overflow-hidden px-4 py-6 sm:px-6 lg:px-8">
      <div class="hero-curve hero-curve-top" aria-hidden="true"></div>
      <div class="hero-curve hero-curve-bottom" aria-hidden="true"></div>
      <div class="hero-ring hero-ring-left" aria-hidden="true"></div>
      <div class="hero-ring hero-ring-right" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto flex min-h-[calc(100vh-3rem)] w-full max-w-7xl flex-col">
        <header class="flex items-center justify-between gap-4">
          <a href="/" class="flex items-center gap-3 rounded-full border border-white/10 bg-white/[0.06] px-4 py-2 backdrop-blur">
            <span class="grid h-9 w-9 place-items-center rounded-full bg-white text-lg">🎵</span>
            <span class="text-sm font-black uppercase tracking-[0.22em] text-white">Música Mundial</span>
          </a>
          <a href="#grupos" class="rounded-full border border-white/25 px-5 py-3 text-xs font-black uppercase tracking-[0.18em] text-white transition hover:border-white hover:bg-white hover:text-[#0c0a3e]">Explorar grupos</a>
        </header>

        <div class="grid flex-1 items-center gap-10 py-10 lg:grid-cols-[0.82fr_1.18fr_0.82fr] lg:py-0">
          <aside class="hidden h-full min-h-[620px] flex-col justify-between lg:flex" aria-label="Selecciones destacadas izquierda">
            <div class="hero-polaroid rotate-[-4deg] self-start">
              <div class="hero-polaroid-art bg-gradient-to-br from-emerald-500 via-white to-red-500">
                <span>🇲🇽</span>
              </div>
              <p>México abre la ruta sonora</p>
            </div>
            <div class="hero-polaroid hero-polaroid-muted rotate-[3deg] self-end">
              <div class="hero-polaroid-art bg-gradient-to-br from-sky-400 via-white to-sky-300">
                <span>🇦🇷</span>
              </div>
              <p>Rituales de hinchada, beats y playlists</p>
            </div>
          </aside>

          <div class="mx-auto max-w-4xl text-center">
            <div class="mx-auto grid max-w-md grid-cols-3 gap-3 text-center">
              <div class="hero-stat">
                <strong>{worldCupGroups.length}</strong>
                <span>Grupos</span>
              </div>
              <div class="hero-stat">
                <strong>{teams.length}</strong>
                <span>Selecciones</span>
              </div>
              <div class="hero-stat">
                <strong>{readyCount}</strong>
                <span>Embeds</span>
              </div>
            </div>

            <p class="mt-9 text-sm font-black uppercase tracking-[0.28em] text-cyan-200 md:text-base">Soundtracks del Mundial 2026</p>
            <h1 class="mt-4 text-balance text-6xl font-black uppercase leading-[0.88] tracking-[-0.08em] text-white sm:text-7xl md:text-8xl lg:text-9xl">
              Música<br />Mundial 26
            </h1>
            <p class="mx-auto mt-7 max-w-2xl text-balance text-lg font-semibold leading-8 text-indigo-100 md:text-xl">
              Una radio visual del torneo: cada selección con sus colores, su grupo y una playlist pública de Spotify para escuchar lo que suena en el país.
            </p>

            <div class="mx-auto mt-10 max-w-3xl rounded-[2rem] border border-white/12 bg-[#080731]/80 p-3 shadow-2xl shadow-black/30 backdrop-blur md:rounded-[2.25rem] md:p-4">
              <div class="grid gap-3 rounded-[1.45rem] bg-[#050420] p-4 text-left md:grid-cols-3 md:p-5">
                <div class="hero-filter-item">
                  <span>📍</span>
                  <div>
                    <p>Grupo</p>
                    <strong>Elige A–L</strong>
                  </div>
                </div>
                <div class="hero-filter-item">
                  <span>🏆</span>
                  <div>
                    <p>Selección</p>
                    <strong>48 soundtracks</strong>
                  </div>
                </div>
                <div class="hero-filter-item">
                  <span>🎧</span>
                  <div>
                    <p>Playlist</p>
                    <strong>Spotify embed</strong>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
              <a href="#grupos" class="rounded-full bg-white px-8 py-4 text-sm font-black uppercase tracking-[0.16em] text-[#0d0a45] shadow-xl shadow-black/20 transition hover:-translate-y-0.5 hover:bg-cyan-100">Entrar al mapa sonoro</a>
              <a href="/pais/mx/" class="rounded-full border border-white/30 px-8 py-4 text-sm font-black uppercase tracking-[0.16em] text-white transition hover:-translate-y-0.5 hover:border-cyan-200 hover:text-cyan-100">Ver México</a>
            </div>
          </div>

          <aside class="hidden h-full min-h-[620px] flex-col justify-between lg:flex" aria-label="Selecciones destacadas derecha">
            <div class="hero-polaroid rotate-[4deg] self-end">
              <div class="hero-polaroid-art bg-gradient-to-br from-blue-700 via-white to-red-600">
                <span>🇺🇸</span>
              </div>
              <p>Host country, stadium noise, charts</p>
            </div>
            <div class="hero-polaroid rotate-[-2deg] self-start">
              <div class="hero-polaroid-art bg-gradient-to-br from-green-500 via-yellow-300 to-blue-600">
                <span>🇧🇷</span>
              </div>
              <p>Colores de bandera como portada musical</p>
            </div>
          </aside>
        </div>

        <div class="grid gap-3 pb-4 sm:grid-cols-3 lg:hidden">
          {heroTeams.map((team) => (
            <div class="rounded-3xl border border-white/10 bg-white/[0.07] p-3 backdrop-blur">
              <div class={`h-24 rounded-2xl bg-gradient-to-br ${team.colors} grid place-items-center text-4xl shadow-inner shadow-black/20`}>{team.flag}</div>
              <p class="mt-3 text-sm font-black text-white">{team.name}</p>
              <p class="text-xs text-indigo-200">{team.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <section class="rounded-[2rem] border border-amber-300/20 bg-amber-300/10 p-5 text-sm leading-7 text-amber-50">
        <strong>Nota de producto:</strong> esta versión evita backend, login y API de Spotify. Los embeds se actualizan desde Spotify cuando la playlist pública cambia. Las selecciones sin ID curado muestran un fallback para completar manualmente después.
      </section>

      <nav class="mt-8 flex flex-wrap gap-2" aria-label="Selector de grupos">
        {worldCupGroups.map((group) => (
          <a href={`#grupo-${group.group}`} class="rounded-full border border-white/10 bg-white/[0.05] px-4 py-2 text-sm font-bold text-slate-200 transition hover:border-limewave hover:text-limewave">Grupo {group.group}</a>
        ))}
      </nav>

      <div id="grupos" class="mt-8 grid gap-6">
        {worldCupGroups.map((group) => <GroupSection group={group} />)}
      </div>
    </section>
  </main>
</BaseLayout>
