---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpotifyEmbed from '../../components/SpotifyEmbed.astro';
import TeamCard from '../../components/TeamCard.astro';
import { teams } from '../../data/worldCupGroups.js';
import { getSpotifySource } from '../../data/musicSources.js';

export function getStaticPaths() {
  return teams.map((team) => ({ params: { slug: team.slug }, props: { team } }));
}

const { team } = Astro.props;
const source = getSpotifySource(team);
const groupMates = teams.filter((item) => item.group === team.group && item.slug !== team.slug);
---
<BaseLayout title={`${team.name} | Música Mundial`} description={`Playlist y soundtrack de ${team.name} para el Mundial 2026.`}>
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <a href="/" class="inline-flex items-center gap-2 border border-slate-950 text-slate-950 hover:bg-slate-950 hover:text-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-5 py-2 text-xs font-black uppercase tracking-wider transition-all duration-200">← Volver a grupos</a>

    <section class="mt-6 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="rounded-[2.5rem] rounded-bl-[80px] bg-[#12135a] p-8 md:p-10 text-white shadow-xl">
        <img
          src={`https://play.fifa.com/media/image/bracket_predictor/flags/world_cup_2026/${team.fifaCode}.png`}
          alt={`Bandera de ${team.name}`}
          class="h-16 w-auto object-contain"
        />
        <p class="mt-6 text-xs font-extrabold uppercase tracking-[0.35em] text-cyan-200">Grupo {team.group}</p>
        <h1 class="mt-3 text-5xl font-black leading-none text-white md:text-6xl">{team.name}</h1>
        <p class="mt-4 text-lg leading-8 text-indigo-100">
          Soundtrack estático con un embed público de Spotify. Si la playlist se actualiza en Spotify, la web refleja el cambio sin backend ni cron jobs.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
            <p class="text-sm text-indigo-200">Código</p>
            <p class="mt-1 text-2xl font-black text-white">{team.countryCode}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
            <p class="text-sm text-indigo-200">Estado musical</p>
            <p class="mt-1 text-lg font-black text-white">{source.label}</p>
          </div>
        </div>
        <p class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm leading-7 text-indigo-100">{source.sourceNote}</p>
        <a href={source.openUrl} target="_blank" rel="noreferrer" class="mt-6 inline-flex border-2 border-white bg-white text-[#12135a] hover:bg-[#12135a] hover:text-white hover:border-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-6 py-3 text-xs font-black uppercase tracking-wider transition-all duration-200">Abrir en Spotify</a>
      </div>

      <SpotifyEmbed source={source} title={`Top 50 Spotify ${team.name}`} />
    </section>

    <section class="mt-10">
      <div class="mb-5 flex items-center justify-between gap-3">
        <div>
          <p class="text-xs font-extrabold uppercase tracking-[0.32em] text-indigo-600">También en el grupo {team.group}</p>
          <h2 class="mt-2 text-3xl font-black text-slate-900">Rivales musicales</h2>
        </div>
        <a href={`/grupo/${team.group.toLowerCase()}/`} class="border border-slate-950 text-slate-950 hover:bg-slate-950 hover:text-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-5 py-2 text-xs font-black uppercase tracking-wider transition-all duration-200">Ver grupo</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {groupMates.map((mate) => <TeamCard team={mate} />)}
      </div>
    </section>
  </main>
</BaseLayout>
