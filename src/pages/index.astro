---
import BaseLayout from "../layouts/BaseLayout.astro";
import { teams, worldCupGroups } from "../data/worldCupGroups.js";
import { getSpotifySource } from "../data/musicSources.js";
import GroupSection from "../components/GroupSection.astro";

const readyCount = teams.filter(
  (team) => getSpotifySource(team).status === "ready",
).length;
---

<BaseLayout title="Música Mundial | Soundtracks del Mundial 2026">
  <main>
    <div
      class="bg-[#12135a] rounded-bl-[40px] md:rounded-bl-[80px] lg:rounded-bl-[360px] flex min-h-screen px-4 py-6 sm:px-6 lg:px-8"
      aria-label="Hero Música Mundial"
    >
      <div
        class="mx-auto flex min-h-[calc(100vh-3rem)] w-full max-w-7xl flex-col"
      >
        <div
          id="hero-content"
          class="mx-auto flex flex-1 items-center py-10 text-center"
        >
          <div class="mx-auto max-w-4xl">
            <p
              class="mt-9 text-sm font-black uppercase text-cyan-200 md:text-base"
            >
              Soundtracks del Mundial 2026
            </p>
            <h1
              class="mt-4 text-balance text-6xl font-black uppercase leading-[0.88] text-white sm:text-7xl md:text-8xl lg:text-9xl"
            >
              Música<br />Mundial 26
            </h1>
            <p
              class="mx-auto mt-7 max-w-2xl text-balance text-lg font-semibold leading-8 text-indigo-100 md:text-xl"
            >
              Una radio visual del torneo: cada selección con sus colores, su
              grupo y una playlist pública de Spotify para escuchar lo que suena
              en el país.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <section id="grupos" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <nav class="mt-12 flex flex-wrap gap-2" aria-label="Selector de grupos">
      {
        worldCupGroups.map((group) => (
          <a
            href={`#grupo-${group.group}`}
            class="border border-slate-950 text-slate-950 hover:bg-slate-950 hover:text-white rounded-tl-none rounded-tr-full rounded-br-full rounded-bl-full px-5 py-2.5 text-xs font-black uppercase tracking-wider transition-all duration-200"
          >
            Grupo {group.group}
          </a>
        ))
      }
    </nav>

    <div class="mt-8 grid gap-6">
      {worldCupGroups.map((group) => <GroupSection group={group} />)}
    </div>
  </section>

  <script>
    // Restore scroll position if returning from a country or group page
    const referrer = document.referrer;
    const isFromDetail = referrer && (referrer.includes("/pais/") || referrer.includes("/grupo/"));
    
    if (isFromDetail) {
      const savedScroll = sessionStorage.getItem("homeScrollPosition");
      if (savedScroll !== null) {
        const scrollY = parseInt(savedScroll, 10);
        
        const html = document.documentElement;
        const originalScrollBehavior = html.style.scrollBehavior;
        html.style.scrollBehavior = "auto";
        window.scrollTo(0, scrollY);
        html.style.scrollBehavior = originalScrollBehavior;

        // Reveal the page body now that it is scrolled to the target position
        html.classList.remove("js-scroll-restoring");

        // Re-apply in requestAnimationFrame to account for rendering/layout shifts
        requestAnimationFrame(() => {
          html.style.scrollBehavior = "auto";
          window.scrollTo(0, scrollY);
          html.style.scrollBehavior = originalScrollBehavior;
        });

        // Re-apply with a small timeout as a final fallback
        setTimeout(() => {
          html.style.scrollBehavior = "auto";
          window.scrollTo(0, scrollY);
          html.style.scrollBehavior = originalScrollBehavior;
        }, 100);
      } else {
        document.documentElement.classList.remove("js-scroll-restoring");
      }
    } else {
      // Clear stale scroll position on a fresh navigation
      sessionStorage.removeItem("homeScrollPosition");
      document.documentElement.classList.remove("js-scroll-restoring");
    }

    // Save scroll position when the user scrolls
    window.addEventListener("scroll", () => {
      sessionStorage.setItem("homeScrollPosition", window.scrollY.toString());
    }, { passive: true });
  </script>
</BaseLayout>
