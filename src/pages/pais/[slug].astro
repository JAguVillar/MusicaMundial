---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpotifyEmbed from '../../components/SpotifyEmbed.astro';
import TeamCard from '../../components/TeamCard.astro';
import { teams } from '../../data/worldCupGroups.js';
import { getSpotifySource } from '../../data/musicSources.js';

export function getStaticPaths() {
  return teams.map((team) => ({ params: { slug: team.slug }, props: { team } }));
}

const { team } = Astro.props;
const source = getSpotifySource(team);
const groupMates = teams.filter((item) => item.group === team.group && item.slug !== team.slug);
---
<BaseLayout title={`${team.name} | Música Mundial`} description={`Playlist y soundtrack de ${team.name} para el Mundial 2026.`}>
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <a href="/" class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.05] px-4 py-2 text-sm font-bold text-slate-200 transition hover:border-limewave hover:text-limewave">← Volver a grupos</a>

    <section class="mt-6 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="rounded-[2.5rem] border border-white/10 bg-white/[0.07] p-7 shadow-2xl shadow-black/25 backdrop-blur md:p-9">
        <span class="text-7xl" aria-hidden="true">{team.flag}</span>
        <p class="mt-6 text-xs font-black uppercase tracking-[0.35em] text-limewave">Grupo {team.group}</p>
        <h1 class="mt-3 text-5xl font-black text-white md:text-6xl">{team.name}</h1>
        <p class="mt-4 text-lg leading-8 text-slate-200">
          Soundtrack estático con un embed público de Spotify. Si la playlist se actualiza en Spotify, la web refleja el cambio sin backend ni cron jobs.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
            <p class="text-sm text-slate-400">Código</p>
            <p class="mt-1 text-2xl font-black text-white">{team.countryCode}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
            <p class="text-sm text-slate-400">Estado musical</p>
            <p class="mt-1 text-lg font-black text-white">{source.label}</p>
          </div>
        </div>
        <p class="mt-6 rounded-2xl border border-white/10 bg-black/25 p-4 text-sm leading-7 text-slate-300">{source.sourceNote}</p>
        <a href={source.openUrl} target="_blank" rel="noreferrer" class="mt-6 inline-flex rounded-full bg-limewave px-6 py-3 text-sm font-black text-pitch transition hover:-translate-y-0.5 hover:bg-white">Abrir en Spotify</a>
      </div>

      <SpotifyEmbed source={source} title={`Top 50 Spotify ${team.name}`} />
    </section>

    <section class="mt-10">
      <div class="mb-5 flex items-center justify-between gap-3">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.32em] text-limewave">También en el grupo {team.group}</p>
          <h2 class="mt-2 text-3xl font-black text-white">Rivales musicales</h2>
        </div>
        <a href={`/grupo/${team.group.toLowerCase()}/`} class="rounded-full border border-white/15 px-4 py-2 text-sm font-bold text-slate-200 transition hover:border-limewave hover:text-limewave">Ver grupo</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {groupMates.map((mate) => <TeamCard team={mate} />)}
      </div>
    </section>
  </main>
</BaseLayout>
