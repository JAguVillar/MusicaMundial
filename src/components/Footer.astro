---
import { worldCupAnthems } from "../data/worldCupAnthems.js";
import SpotifyIcon from "./icons/spotify.astro";
import PillButton from "./ui/PillButton.astro";
import {
  Play,
  Headphones,
  Music,
  Github,
  Twitter,
  Instagram,
  ArrowRight,
} from "lucide-astro";

const hostCountries = {
  1990: "Italia",
  1994: "EE.UU.",
  1998: "Francia",
  2002: "Corea / Japón",
  2006: "Alemania",
  2010: "Sudáfrica",
  2014: "Brasil",
  2018: "Rusia",
  2022: "Catar",
};
---

<footer class="bg-[#04061e] border-t border-white/5 mt-20 relative overflow-hidden">
  <!-- Imagen de fondo dinámica del himno actual -->
  <div 
    id="slideshow-bg"
    class="absolute inset-0 bg-cover bg-center transition-opacity duration-300 opacity-0 blur-[1px] pointer-events-none z-0"
  ></div>
  <!-- Máscara de degradado para fundir la imagen con el fondo oscuro general -->
  <div class="absolute inset-0 bg-gradient-to-t from-[#04061e] via-transparent pointer-events-none z-0"></div>

  <!-- Glow Effect Background -->
  <div class="absolute top-0 left-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-[#3ddcff]/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 translate-y-1/2 w-[500px] h-[500px] bg-indigo-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 relative z-10">
    <!-- SECCIÓN PRINCIPAL: Himnos de los Mundiales -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl md:text-5xl leading-tight">
          Himnos de los Mundiales
        </h2>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-indigo-200/60 font-medium">
          Revive las canciones que marcaron cada Copa del Mundo y acompañaron a generaciones de aficionados.
        </p>
      </div>

      <PillButton
        href="https://open.spotify.com/playlist/2D2SpKF7DNpPEf2sBGCV7S?si=649511fb0af54e2f"
        target="_blank"
        rel="noopener noreferrer"
        themeClass="border-2 border-white bg-white text-[#04061e] hover:bg-transparent hover:text-white hover:border-white px-6 py-3"
        class="self-start md:self-auto flex-shrink-0"
      >
        <SpotifyIcon class="w-4 h-4 text-[#1db954]" />
        Abrir en Spotify
      </PillButton>
    </div>

    <!-- SLIDESHOW DE HIMNOS (PowerPoint Style - Flex Layout) -->
    <div class="flex items-center justify-between gap-4 md:gap-8 max-w-5xl mx-auto mt-8 select-none">
      <!-- Botón Anterior -->
      <PillButton 
        id="anthem-prev"
        href="#"
        themeClass="border border-white/10 text-indigo-200/60 hover:bg-white hover:text-[#04061e] hover:border-white transition-all duration-200 px-4 py-2"
        ariaLabel="Himno anterior"
        class="flex-shrink-0 invisible pointer-events-none"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Anterior</span>
      </PillButton>

      <!-- Contenedor del Slide Activo (Sin bordes y con esquinas estilo País) -->
      <div 
        id="anthems-slideshow-container"
        class="flex-1 bg-[#0e123f]/10 rounded-[2.5rem] rounded-bl-[80px] p-6 md:p-10 transition-all duration-500"
      >
        {
          worldCupAnthems.map((anthem, index) => {
            const hostCountry = hostCountries[anthem.year] || "";

            return (
              <div 
                class={`anthem-slide flex flex-col md:flex-row items-center gap-6 md:gap-10 transition-all duration-300 ${index === 0 ? "active" : "hidden"}`}
                data-slide-index={index}
                data-bg-url={anthem.background}
              >
                <!-- Portada de Álbum con Play Overlay -->
                <div 
                  class="w-full md:w-[280px] aspect-[16/10] flex-shrink-0 rounded-2xl overflow-hidden bg-slate-950/80 shadow-md relative group cursor-pointer border border-white/10"
                  data-play-btn
                  data-youtube-id={anthem.youtubeId}
                >
                  <img
                    src={anthem.cover}
                    alt={`Portada de ${anthem.title}`}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                  />
                  <div class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="bg-white text-black p-3.5 rounded-full shadow-2xl transform scale-90 group-hover:scale-100 transition duration-300">
                      <Play class="w-5 h-5 fill-current" />
                    </div>
                  </div>
                </div>

                <!-- Datos del Himno -->
                <div class="flex-1 text-center md:text-left">
                  <div class="flex flex-wrap gap-2.5 items-center justify-center md:justify-start mb-3">
                    <span class={`inline-block px-2.5 py-0.5 rounded-full text-[10px] font-black tracking-wider uppercase border ${anthem.badgeColor}`}>
                      {anthem.year}
                    </span>
                    {hostCountry && (
                      <span class="text-xs text-indigo-200/50 font-bold uppercase tracking-wider">
                        Mundial {hostCountry}
                      </span>
                    )}
                  </div>
                  <h3 class="text-2xl md:text-3xl font-black text-white leading-tight group-hover:text-[#3ddcff] transition duration-200">
                    {anthem.title}
                  </h3>
                  <p class="text-sm md:text-base text-indigo-200/50 mt-1.5 font-bold">
                    {anthem.artist}
                  </p>
                  <p class="text-xs md:text-sm text-indigo-200/30 mt-4 leading-relaxed font-medium">
                    Haz clic en la portada para reproducir el video oficial y recordar los mejores momentos de la Copa Mundial de {anthem.year}.
                  </p>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Botón Siguiente -->
      <PillButton 
        id="anthem-next"
        href="#"
        themeClass="border border-white/10 text-indigo-200/60 hover:bg-white hover:text-[#04061e] hover:border-white transition-all duration-200 px-4 py-2"
        ariaLabel="Himno siguiente"
        class="flex-shrink-0"
      >
        <span class="hidden sm:inline">Siguiente</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </PillButton>
    </div>


